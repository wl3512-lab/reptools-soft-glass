# RepTools Environment Variables
# Copy this to .env and fill in your values

# Flask secret key (auto-generated on Render)
SECRET_KEY=change-me-to-something-random

# Discord Webhook - get from Discord channel settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: separate channel for analytics reports
DISCORD_WEBHOOK_ANALYTICS_URL=

# KakoBuy QC API token
KAKOBUY_TOKEN=your_kakobuy_token

# TrackingMore API key (for package tracking)
TRACKINGMORE_API_KEY=your_trackingmore_key

# DHL API key (optional)
DHL_API_KEY=

# Canada Post API (optional)
CANADA_POST_API_USER=
CANADA_POST_API_PASS=

# Database path (default: reptools.db in project root)
REPTOOLS_DB_PATH=reptools.db
